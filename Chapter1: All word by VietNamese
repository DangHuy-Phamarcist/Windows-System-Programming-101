Cách dễ nhất để có một tệp manifest đẹp để chỉnh sửa là tạo một ứng dụng console C# đơn giản, sau đó thêm vào project một mục Application Manifest File, nó sẽ tạo ra XML ở trên, cùng với các phần tử khác.

Các GUID cho các phiên bản hệ điều hành khác nhau đã được tạo khi những phiên bản đó được phát hành. Nghĩa là không có cách nào một ứng dụng được phát triển trong thời Windows 7 có thể nhận một phiên bản Windows 10, ví dụ. Nếu bỏ chú thích phiên bản Windows 8.1 và chạy lại ứng dụng, output là: *Version: 6.3.9600*

Nếu bỏ chú thích GUID của Windows 10 (dù GUID của Windows 8.1 có được chú thích hay không cũng không quan trọng), sẽ nhận được phiên bản Windows 10 thật sự (điều kiện là nếu chạy trên máy Windows 10): *Version: 10.0.18362*

**Getting the Windows Version**

Vì GetVersionEx đã bị loại bỏ, nên cách đúng để lấy thông tin phiên bản Windows là một bộ API mới đã có sẵn có thể trả về kết quả, nhưng không phải theo dạng số, mà bằng cách trả về true/false cho các câu hỏi về phiên bản Windows. Chúng có trong file header <versionhelpers.h>.

Một số function gồm: IsWindowsXPOrGreater, IsWindowsXPSP3OrGreater, IsWindows7OrGreater, IsWindows8Point1OrGreater, IsWindows10OrGreater, IsWindowsServer. Chúng không nhận gì và trả về TRUE hoặc FALSE. Cách triển khai của chúng sử dụng một hàm liên quan đến phiên bản khác, VerifyVersionInfo: 

```cpp
BOOL VerifyVersionInfo(
		_Inout_ POSVERSIONINFOEX pVersionInformation,
		_In_    DWORD dwTypeMask,
		_In_    **DWORDLONG dwlConditionMask);
```

Hàm này biết cách so sánh các số phiên bản dựa trên các tiêu chí được chỉ định (dwConditionMask), chẳng hạn như số phiên bản chính hoặc phụ. Có thể tìm thấy phần triển khai của tất cả các hàm Boolean bên trong versionhelper.h.

Cách không chính thức để lấy số phiên bản bất kể file manifest mà không cần gọi GetVersionEx. Nó dựa trên một cấu trúc dữ liệu gọi là KUSER_SHARED_DATA được ánh xạ đến mọi tiến trình tại cùng một địa chỉ ảo (0x7FFE0000). Cách khai báo nó được liệt kê trong liên kết Microsoft này: đây. Các số phiên bản Windows là một phần của cấu trúc chung này ở cùng các vị trí. Cách khác để hiển thị số phiên bản Windows:

```cpp
auto sharedUserData = (BYTE*)0x7FFE0000;
printf("Version: %d.%d.%d\n",
		**(ULONG**)(sharedUserData + 0x26c), // major version offset
		**(ULONG**)(sharedUserData + 0x270), // minor version offset
		**(ULONG**)(sharedUserData + 0x260)); // build number offset (Windows 10)
```

Recommended to use the official APIs rather than KUSER_SHARED_DATA

**Exercises**

Write a console application that prints more information about the system than the HelloWin application shown earlier, by calling the following APIs: GetNativeSystemInfo, GetComputerName, GetWindowsDirectory, QueryPerformanceCounter, GetProductInfo, GetComputerObjectName. Handle errors nếu có.

!image.png

*Hình 9: Result*

```cpp
#include <windows.h>
#include <stdio.h>
#include <VersionHelpers.h>
#include <tchar.h>

int systemInfo();
int computerName();
int windowsDirectory();
int queryPerformanceCounter();
int productInfo();
int computerObject();

int main() {
	systemInfo();
	computerName();
	windowsDirectory();
	queryPerformanceCounter();
	productInfo();
	computerObject();
	return 0;
}
int systemInfo() {
	SYSTEM_INFO si;
	GetSystemInfo(&si);
	printf("Processor Architecture: %d\n", si.wProcessorArchitecture);
	printf("Number of Processors: %d\n", si.dwNumberOfProcessors);
	return 0;
}

int computerName() {
	TCHAR computerName[MAX_COMPUTERNAME_LENGTH + 1];
	DWORD size = MAX_COMPUTERNAME_LENGTH + 1;
	if (GetComputerName(computerName, &size)) {
		printf("Computer Name: %ws\n", computerName);
	}
	else {
		printf("Failed to get computer name. Error code: %d\n", GetLastError());
	}
	return 0;
}

int windowsDirectory() {
	TCHAR windowsDir[MAX_PATH];
	UINT result = GetWindowsDirectory(windowsDir, MAX_PATH);
	if (result > 0 && result < MAX_PATH) {
		printf("Windows Directory: %ws\n", windowsDir);
	}
	else {
		printf("Failed to get Windows directory. Error code: %d\n", GetLastError());
	}
	return 0;
}

int queryPerformanceCounter() {
	LARGE_INTEGER counter;
	if (QueryPerformanceCounter(&counter)) {
		printf("Performance Counter: %lld\n", counter.QuadPart);
	}
	else {
		printf("Failed to query performance counter. Error code: %d\n", GetLastError());
	}
	return 0;
}

int productInfo() {
	OSVERSIONINFOEX osvi;
	osvi.dwOSVersionInfoSize = sizeof(OSVERSIONINFOEX);
	if (GetVersionEx((OSVERSIONINFO*)&osvi)) {
		printf("Operating System: Windows %d.%d (Build %d)\n", osvi.dwMajorVersion, osvi.dwMinorVersion, osvi.dwBuildNumber);
	}
	else {
		printf("Failed to get OS version. Error code: %d\n", GetLastError());
	}
	return 0;
}

int computerObject() {
	COMPUTER_NAME_FORMAT format = ComputerNamePhysicalDnsHostname;
	TCHAR computerName[MAX_COMPUTERNAME_LENGTH + 1];
	DWORD size = MAX_COMPUTERNAME_LENGTH + 1;
	if (GetComputerNameEx(format, computerName, &size)) {
		printf("Computer Name (DNS Hostname): %ws\n", computerName);
	}
	else {
		printf("Failed to get computer name. Error code: %d\n", GetLastError());
	}
	return 0;
}
```
